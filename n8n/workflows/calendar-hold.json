        "method": "POST",
        "url": "http://langgraph-agent:8000/api/v1/calendar/hold",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
