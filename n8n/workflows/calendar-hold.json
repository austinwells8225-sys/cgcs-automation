    {
      "parameters": {
        "jsCode": "// Validate and extract hold request parameters\nconst input = $input.first().json.body || $input.first().json;\n\nconst org_name = (input.org_name || '').trim();\nconst date = (input.date || '').trim();\nconst start_time = (input.start_time || '').trim();\nconst end_time = (input.end_time || '').trim();\n\nif (!org_name || !date || !start_time || !end_time) {\n  throw new Error('Missing required fields: org_name, date, start_time, end_time');\n}\n\nreturn [{\n  json: { org_name, date, start_time, end_time }\n}];"
      },
      "id": "validate-hold",
      "name": "Validate Hold Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
