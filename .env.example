# ============================================
# CGCS Unified Agent — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Domain & TLS ---
DOMAIN=cgcs-auto.example.com
ACME_EMAIL=admin@austincc.edu

# --- PostgreSQL ---
POSTGRES_DB=cgcs_events
POSTGRES_USER=cgcs_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- N8N ---
N8N_HOST=n8n.cgcs-auto.example.com
WEBHOOK_URL=https://n8n.cgcs-auto.example.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_CHAR_STRING

# --- LangGraph Agent ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
LANGGRAPH_API_KEY=CHANGE_ME_SHARED_SECRET
LOG_LEVEL=INFO
ENVIRONMENT=production

# --- Webhook Security ---
# Shared secret between CGCS website form / N8N and the agent
WEBHOOK_SECRET=CHANGE_ME_RANDOM_STRING

# --- Admin Email (for human-in-the-loop notifications) ---
ADMIN_EMAIL=austin.wells@austincc.edu

# --- Resilience ---
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
DEAD_LETTER_MAX_FAILURES=3

# --- LangSmith Tracing ---
LANGCHAIN_API_KEY=ls-CHANGE_ME
LANGCHAIN_PROJECT=cgcs-automation
LANGCHAIN_TRACING_V2=true

# --- Google APIs (service account) ---
GOOGLE_SERVICE_ACCOUNT_FILE=/app/credentials/google-service-account.json
GOOGLE_CALENDAR_ID=REPLACE_WITH_CGCS_EVENTS_CALENDAR_ID
PET_TRACKER_SPREADSHEET_ID=REPLACE_WITH_SPREADSHEET_ID

# --- Gmail (domain-wide delegation via service account) ---
# admin@cgcs-acc.org is retired (ACC firewall blocks delivery). Production
# value is austin.wells@austincc.edu — requires ACC Workspace admin to add
# the service account's OAuth client ID to DWD allowlist for @austincc.edu.
GMAIL_DELEGATED_USER=austin.wells@austincc.edu

# When true, send_email and reply_to_thread are short-circuited to log-only.
# create_draft_reply still runs (drafts stay in Gmail, never sent). Use
# during cutover / shadow testing.
EMAIL_DRY_RUN=false

# --- Smartsheet Inbox Poller ---
SMARTSHEET_POLL_ENABLED=true
SMARTSHEET_POLL_MINUTES=5

# --- Email Auto-Send Allowlist (comma-separated) ---
# Set to empty string to force every reply into the approval queue.
EMAIL_AUTO_SEND_ALLOWLIST=stefano.casafrancalaos@austincc.edu,marisela.perez@austincc.edu

# --- Dashboard (cgcs-dashboard service) ---
DASHBOARD_URL=https://ops.cgcs-acc.org
AGENT_API_URL=http://langgraph-agent:8000
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_CHAR_STRING
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME
ALLOWED_EMAIL_DOMAINS=austincc.edu,cgcs-acc.org
